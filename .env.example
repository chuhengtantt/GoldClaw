# ============================================================
# GoldClaw 配置文件
# 复制此文件为 .env 后按需修改
# ============================================================

# --- 金价 API ---
GOLD_API_URL=https://api.gold-api.com/price/XAU
GOLD_API_TIMEOUT=10

# --- OpenClaw Bridge (门铃) ---
# 紧急事件 POST 到此 URL (GoldClaw 自身的 /emergency 端点)
OPENCLAW_BRIDGE_URL=http://localhost:8089/emergency
OPENCLAW_BRIDGE_TIMEOUT=30

# --- 数据库 ---
DB_PATH=data/goldclaw.db

# --- 调度器 (可在 Dashboard 参数配置中动态修改) ---
SCHEDULE_INTERVAL_IDLE=15      # IDLE 态 tick 间隔 (分钟)
SCHEDULE_INTERVAL_WATCH=3      # WATCH 态 tick 间隔 (分钟)

# --- 状态机阈值 (可在 Dashboard 参数配置中动态修改) ---
CYCLE_X=5
THRESHOLD_A=0.003
THRESHOLD_B=0.005
WATCH_DURATION=5
TRIGGER_SLOPE=0.002
SILENCE_PERIOD=30

# --- 初始资金 ---
INITIAL_CASH_A=10000
INITIAL_CASH_B=10000
