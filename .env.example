# Gold API
GOLD_API_URL=https://api.gold-api.com/price/XAU
GOLD_API_TIMEOUT=10

# OpenClaw Bridge (门铃，默认端口 8088)
OPENCLAW_BRIDGE_URL=http://localhost:8088/emergency
OPENCLAW_BRIDGE_TIMEOUT=30

# Database
DB_PATH=data/goldclaw.db

# Scheduler
SCHEDULE_INTERVAL_IDLE=15
SCHEDULE_INTERVAL_WATCH=3

# State Machine Thresholds
CYCLE_X=5
THRESHOLD_A=0.003
THRESHOLD_B=0.005
WATCH_DURATION=5
TRIGGER_SLOPE=0.002
SILENCE_PERIOD=30

# Initial Capital
INITIAL_CASH_A=10000
INITIAL_CASH_B=10000
